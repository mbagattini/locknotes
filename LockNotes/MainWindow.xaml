<Window
    x:Class="LockNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Lock Notes">

    <Grid RequestedTheme="Dark" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="OnCtrlN"/>
            <KeyboardAccelerator Key="O" Modifiers="Control" Invoked="OnCtrlO"/>
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="OnCtrlS"/>
            <KeyboardAccelerator Key="S" Modifiers="Control,Shift" Invoked="OnCtrlShiftS"/>
            <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="OnCtrlW"/>
            <KeyboardAccelerator Key="P" Modifiers="Control" Invoked="OnCtrlP"/>
        </Grid.KeyboardAccelerators>

        <!-- Title bar in stile Notepad: icona app, tab strip e zona di drag.
             I tab item portano solo l'header: gli editor vivono in EditorHost (riga 2),
             cosi' la barra dei menu' puo' stare tra la strip e il contenuto. -->
        <TabView Grid.Row="0"
                 x:Name="Tabs"
                 Background="Transparent"
                 TabWidthMode="SizeToContent"
                 CanReorderTabs="True"
                 IsAddTabButtonVisible="True"
                 AddTabButtonClick="OnAddTabClick"
                 TabCloseRequested="OnTabCloseRequested"
                 SelectionChanged="OnTabSelectionChanged">
            <TabView.Resources>
                <SolidColorBrush x:Key="TabViewBackground" Color="Transparent"/>
                <!-- Come Notepad: la tab selezionata ha lo stesso colore della superficie dell'editor -->
                <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#2E3440"/>
            </TabView.Resources>
            <TabView.TabStripHeader>
                <Image Source="ms-appx:///Assets/locknotes.ico"
                       Width="16" Height="16"
                       Margin="14,0,6,0"
                       VerticalAlignment="Center"/>
            </TabView.TabStripHeader>
            <TabView.TabStripFooter>
                <!-- Spazio vuoto a destra dei tab: e' la drag region della finestra
                     (SetTitleBar in code-behind); MinWidth riserva i pulsanti di sistema -->
                <Grid x:Name="TitleBarDragRegion" Background="Transparent" MinWidth="160"/>
            </TabView.TabStripFooter>
        </TabView>

        <!-- Menu bar: stesso colore della tab selezionata, cosi' tab attiva e menu
             formano una superficie continua come in Notepad -->
        <MenuBar Grid.Row="1" Background="#2E3440">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Nuova scheda" KeyboardAcceleratorTextOverride="Ctrl+N" Click="OnMenuNew"/>
                <MenuFlyoutItem Text="Apri..." KeyboardAcceleratorTextOverride="Ctrl+O" Click="OnMenuOpen"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Salva" KeyboardAcceleratorTextOverride="Ctrl+S" Click="OnMenuSave"/>
                <MenuFlyoutItem Text="Salva tutto" KeyboardAcceleratorTextOverride="Ctrl+Shift+S" Click="OnMenuSaveAll"/>
                <MenuFlyoutItem Text="Chiudi tab" KeyboardAcceleratorTextOverride="Ctrl+W" Click="OnMenuCloseTab"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Cambia Password..." KeyboardAcceleratorTextOverride="Ctrl+P" Click="OnMenuChangePassword"/>
                <MenuFlyoutItem Text="Codice di recupero..." Click="OnMenuRecoveryCode"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Esci" Click="OnMenuExit"/>
            </MenuBarItem>
            <MenuBarItem Title="Visualizza">
                <MenuFlyoutItem Text="Aumenta dimensione testo" KeyboardAcceleratorTextOverride="Ctrl++" Click="OnMenuFontSizeUp"/>
                <MenuFlyoutItem Text="Riduci dimensione testo"  KeyboardAcceleratorTextOverride="Ctrl+-"  Click="OnMenuFontSizeDown"/>
            </MenuBarItem>
            <MenuBarItem Title="?">
                <MenuFlyoutItem Text="Informazioni..." Click="OnMenuAbout"/>
            </MenuBarItem>
        </MenuBar>

        <!-- Avvisi non bloccanti (es. file ricaricato perche' modificato da un altro utente) -->
        <InfoBar Grid.Row="2"
                 x:Name="NoticeBar"
                 Severity="Informational"
                 IsOpen="False"/>

        <!-- Editor dei tab: un Grid (editor + placeholder) per file, creato in
             code-behind (DocumentTab); e' visibile solo quello del tab attivo -->
        <Grid Grid.Row="3" x:Name="EditorHost" Background="#232831"/>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="#2E3440"
                BorderBrush="#4C566A"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="lblFilePath"
                           Foreground="#9EAABE"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="lblInfo"
                           Foreground="#88C0D0"
                           FontSize="13"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
