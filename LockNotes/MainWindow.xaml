<Window
    x:Class="LockNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Lock Notes">

    <Grid RequestedTheme="Dark" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="OnCtrlS"/>
            <KeyboardAccelerator Key="O" Modifiers="Control" Invoked="OnCtrlO"/>
            <KeyboardAccelerator Key="P" Modifiers="Control" Invoked="OnCtrlP"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom title bar drag region -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <TextBlock x:Name="TitleText"
                       VerticalAlignment="Center"
                       Margin="16,0,148,0"
                       Foreground="#D8DEE9"
                       FontSize="12"/>
        </Grid>

        <!-- Menu bar -->
        <MenuBar Grid.Row="1" Background="#232831">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Salva" KeyboardAcceleratorTextOverride="Ctrl+S" Click="OnMenuSave"/>
                <MenuFlyoutItem Text="Apri altro..." KeyboardAcceleratorTextOverride="Ctrl+O" Click="OnMenuOpen"/>
                <MenuFlyoutItem Text="Cambia Password..." KeyboardAcceleratorTextOverride="Ctrl+P" Click="OnMenuChangePassword"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Esci" Click="OnMenuExit"/>
            </MenuBarItem>
            <MenuBarItem Title="Visualizza">
                <MenuFlyoutItem Text="Aumenta dimensione testo" KeyboardAcceleratorTextOverride="Ctrl++" Click="OnMenuFontSizeUp"/>
                <MenuFlyoutItem Text="Riduci dimensione testo"  KeyboardAcceleratorTextOverride="Ctrl+-"  Click="OnMenuFontSizeDown"/>
            </MenuBarItem>
            <MenuBarItem Title="?">
                <MenuFlyoutItem Text="Informazioni..." Click="OnMenuAbout"/>
            </MenuBarItem>
        </MenuBar>

        <!-- Main text editor -->
        <RichEditBox Grid.Row="2"
                 x:Name="txtContent"
                 TextWrapping="NoWrap"
                 FontFamily="Cascadia Code"
                 FontWeight="Medium"
                 Background="#2E3440"
                 Foreground="#D8DEE9"
                 BorderThickness="0"
                 CornerRadius="0"
                 Padding="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 IsSpellCheckEnabled="False"
                 IsTextPredictionEnabled="False"
                 VerticalContentAlignment="Top"
                 TextChanged="OnTextChanged"
                 KeyDown="OnTextBoxKeyDown"
                 Paste="OnPaste">
            <RichEditBox.SelectionHighlightColor>
                <SolidColorBrush Color="#4C566A"/>
            </RichEditBox.SelectionHighlightColor>
            <RichEditBox.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="#2E3440"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2E3440"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2E3440"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="#D8DEE9"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#D8DEE9"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#D8DEE9"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
            </RichEditBox.Resources>
        </RichEditBox>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="#2E3440"
                BorderBrush="#4C566A"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="lblFilePath"
                           Foreground="#9EAABE"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="lblInfo"
                           Foreground="#88C0D0"
                           FontSize="13"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
